# Lidarr
LIDARR_URL=http://192.168.10.10:8686
LIDARR_API_KEY=your_lidarr_api_key_here
LIDARR_ROOT_FOLDER=/mediafiles/music

# Profile names (case-insensitive). Leave empty to use the first available.
LIDARR_QUALITY_PROFILE=Lossless
LIDARR_METADATA_PROFILE=Standard

# Monitor mode for added artists:
#   none   — добавить без мониторинга, ничего не качать (для ручной проверки)
#   future — мониторить только новые релизы (рекомендуется)
#   all    — качать всю дискографию сразу (осторожно — много GB!)
LIDARR_MONITOR_MODE=future

# Discovery settings
DISCOVERY_DEPTH=1      # 1 = direct similar only | 2 = similar of similar
BATCH_SIZE=50          # MBIDs per request to ListenBrainz Labs
MIN_OVERLAP_SCORE=10   # minimum number of your artists pointing to a candidate
MAX_OVERLAP_SCORE=80   # 0 = no upper limit; higher = more mainstream
MAX_ADD=10             # max artists to add per run

# Set to true for a trial run — logs candidates without touching Lidarr
DRY_RUN=true
