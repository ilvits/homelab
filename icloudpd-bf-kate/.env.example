# Kate's Apple ID — regular email, NOT app-specific password
APPLE_ID=kate@example.com

# Notifications — start with "none" for first init, switch to "Telegram" after success
NOTIFICATION_TYPE=none

# Telegram (optional — leave blank if NOTIFICATION_TYPE=none)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Sync interval in seconds (7200 = 2 hours, default)
SYNC_INTERVAL=7200
