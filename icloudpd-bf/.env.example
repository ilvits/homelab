# Apple ID — primary email (regular Apple ID, NOT app-specific password)
APPLE_ID=tsoyilya@gmail.com

# Notifications — set to "Telegram" once init is verified, leave "none" for first run
NOTIFICATION_TYPE=none

# Telegram (optional — leave blank if NOTIFICATION_TYPE=none)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Sync interval in seconds (7200 = 2 hours, default)
SYNC_INTERVAL=7200
