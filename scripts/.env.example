# scripts/.env.example
# Copy to .env and fill in real values
# DO NOT commit .env to git — only this file

# --- Telegram (watchtower bot — used only by watchtower-check.sh) ---
# Apprise URL format: telegram://BOT_TOKEN@telegram?channels=CHANNEL_ID:TOPIC_ID
# CHANNEL_ID — supergroup ID (with minus sign)
# TOPIC_ID   — topic ID (omit if not needed)
TELEGRAM_URL=telegram://bot_token@telegram?channels=channel_id:topic_id

# --- Uptime Kuma ---
# Heartbeat token for glacier-backup
# Settings -> Monitors -> New Monitor -> Heartbeat -> copy Push URL token
GLACIER_HEARTBEAT_TOKEN=your_uptime_kuma_heartbeat_token_here
