# scripts/.env.example
# Copy to .env and fill in real values
# DO NOT commit .env to git — only this file

# --- Telegram (watchtower bot — used only by watchtower-check.sh) ---
# Apprise URL format: telegram://BOT_TOKEN@telegram?channels=CHANNEL_ID:TOPIC_ID
# CHANNEL_ID — supergroup ID (with minus sign)
# TOPIC_ID   — topic ID (omit if not needed)
TELEGRAM_URL=telegram://bot_token@telegram?channels=channel_id:topic_id

# --- Uptime Kuma ---
# Heartbeat token for glacier-backup
# Settings -> Monitors -> New Monitor -> Heartbeat -> copy Push URL token
GLACIER_HEARTBEAT_TOKEN=your_uptime_kuma_heartbeat_token_here

# --- Glacier backup ---
# Root directory containing all photo libraries
PHOTO_ROOT=/mnt/user/photoLibraries

# Account subfolder names (used in paths and archive naming)
ACCOUNT1=account1
ACCOUNT2=account2

# rclone remote name (defined in /root/.config/rclone/rclone.conf)
RCLONE_REMOTE=photos-crypt

# Upload bandwidth limit (rclone --bwlimit), e.g. 2M, 10M, 0 for unlimited
BWLIMIT=2M

# Path to private git repo where ledger.csv is backed up
LEDGER_REPO=/root/your-private-repo

# --- VPS (sync-vaultwarden.sh) ---
VPS_HOST=your.vps.ip.or.hostname
VPS_USER=root
# Full path to vaultwarden data dir on VPS (parent dir must contain docker-compose.yml)
VPS_VAULTWARDEN_DATA=/opt/stacks/vaultwarden-backup/data
