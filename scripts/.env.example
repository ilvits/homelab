# =============================================================================
# scripts/.env — environment variables for homelab scripts
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# --- Glacier backup (backup-photos-glacier.sh) ---

# Base path to photo libraries on Unraid array
PHOTO_ROOT=/mnt/user/photoLibraries

# Account names — used in archive filenames and S3 subdirectory paths
# Example: ilvits_icloud_2023_05.tar uploaded to s3://bucket/ilvits/
ACCOUNT1=ilvits
ACCOUNT2=kate

# rclone remote name as defined in /root/.config/rclone/rclone.conf
# Must point to an encrypted S3 remote (type = crypt wrapping type = s3)
RCLONE_REMOTE=photos-crypt

# Bandwidth limit for rclone uploads (e.g. 30M, 50M, 0 = unlimited)
BWLIMIT=30M

# Absolute path to the private git repository that stores ledger.csv
LEDGER_REPO=/root/homelab-private

# Uptime Kuma heartbeat push token (from Monitor → Heartbeat → Push URL)
# Format: the token part only — full URL is built in the script
GLACIER_HEARTBEAT_TOKEN=your_token_here

# --- Telegram (watchtower-check.sh) ---

# Full Telegram Bot API URL for direct notifications (watchtower bot)
# Format: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
TELEGRAM_URL=https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
