# ── Telegram ──────────────────────────────────────────────────────────────────
# Токен от @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Твой личный chat_id (узнать: написать @userinfobot)
CHAT_ID=123456789

# ── iCloud — ilvits ───────────────────────────────────────────────────────────
ILVITS_USERNAME=ilvits@icloud.com
ILVITS_PASSWORD=super-secret-password

# Структура папок для фото (strftime-формат)
# {:%Y/%m}      → 2024/03
# {:%Y/%m/%d}   → 2024/03/15
# (пустая строка → все файлы в корень download_dir)
ILVITS_FOLDER_STRUCTURE={:%Y/%m}

# ── iCloud — kate ─────────────────────────────────────────────────────────────
KATE_USERNAME=kate@icloud.com
KATE_PASSWORD=super-secret-password

KATE_FOLDER_STRUCTURE={:%Y/%m}

# ── Общие настройки ───────────────────────────────────────────────────────────
# Интервал синхронизации в секундах (3600 = 1 час)
SYNC_INTERVAL=3600
