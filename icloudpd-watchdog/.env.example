# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal chat_id (find it by messaging @userinfobot)
CHAT_ID=123456789

# ── iCloud — ilvits ───────────────────────────────────────────────────────────
ILVITS_USERNAME=ilvits@icloud.com
ILVITS_PASSWORD=super-secret-password

# Folder structure for downloaded photos (strftime format)
# {:%Y/%m}      -> 2024/03
# {:%Y/%m/%d}   -> 2024/03/15
# (empty string -> all files in root of download_dir)
ILVITS_FOLDER_STRUCTURE={:%Y/%m}

# ── iCloud — kate ─────────────────────────────────────────────────────────────
KATE_USERNAME=kate@icloud.com
KATE_PASSWORD=super-secret-password

KATE_FOLDER_STRUCTURE={:%Y/%m}

# ── General settings ──────────────────────────────────────────────────────────
# Sync interval in seconds (3600 = 1 hour)
SYNC_INTERVAL=3600
